"/><meta name=\"robots\" content=\"index, follow\"/><meta name=\"googlebot\" content=\"index, follow\"/><meta property=\"og:title\" content=\"Glyph — QR codes that cost less and tell you more\"/><meta property=\"og:description\" content=\"Free QR code generator with built-in scan analytics. Track every scan — location, device, time. $3/month instead of $49.\"/><meta property=\"og:url\" content=\"https://glyph.calyvent.com\"/><meta property=\"og:site_name\" content=\"Glyph\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Glyph — Free QR Code Generator with Analytics\"/><meta name=\"twitter:description\" content=\"Generate, scan, and track QR codes. $3/month replaces $49/month tools.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"Glyph\",\"applicationCategory\":\"BusinessApplication\",\"operatingSystem\":\"Web\",\"url\":\"https://glyph.calyvent.com\",\"description\":\"Free QR code generator with built-in scan analytics. Generate, scan, and track QR codes. Replaces tools like Beaconstac and QR Tiger at 90% lower cost.\",\"offers\":[{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\",\"name\":\"Free\",\"description\":\"Unlimited QR generation and scanning\"},{\"@type\":\"Offer\",\"price\":\"3.00\",\"priceCurrency\":\"USD\",\"name\":\"Pro\",\"description\":\"Scan analytics, custom colors, logo embedding, bulk generation\"}],\"creator\":{\"@type\":\"Organization\",\"name\":\"Calyvent\",\"url\":\"https://calyvent.com\"},\"datePublished\":\"2026-03-25\",\"dateModified\":\"2026-03-25\"}</script><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col bg-[var(--surface)] text-[var(--text-primary)]\"><div hidden=\"\"><!--$--><!--/$--></div><nav class=\"fixed top-0 left-0 right-0 z-50 bg-[var(--surface)]/90 backdrop-blur-md border-b border-[var(--border-subtle)]\"><div class=\"max-w-5xl mx-auto px-6 h-14 flex items-center justify-between\"><a class=\"flex items-center gap-2 text-[var(--text-primary)] no-underline\" href=\"/\"><span class=\"w-2 h-2 rounded-full bg-[var(--accent)]\"></span><span class=\"text-[15px] font-medium tracking-tight lowercase\">glyph</span></a><div class=\"flex items-center gap-6\"><a class=\"text-[12px] font-medium tracking-wide lowercase no-underline transition-colors text-[var(--text-secondary)] hover:text-[var(--text-primary)]\" href=\"/scan\">scan</a><a class=\"text-[12px] font-medium tracking-wide lowercase no-underline transition-colors text-[var(--text-secondary)] hover:text-[var(--text-primary)]\" href=\"/pricing\">pricing</a><a class=\"text-[12px] font-medium tracking-wide lowercase no-underline transition-colors text-[var(--text-secondary)] hover:text-[var(--text-primary)]\" href=\"/dashboard\">dashboard</a></div></div></nav><main class=\"flex-1 pt-14\"><section class=\"max-w-5xl mx-auto px-6 pt-20 pb-16\"><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12 items-start\"><div class=\"flex flex-col gap-6 stagger lg:pt-8\"><h1 class=\"text-[36px] lg:text-[44px] font-medium leading-[1.15] tracking-tight lowercase\">scan. track. know.</h1><p class=\"text-[16px] text-[var(--text-secondary)] leading-relaxed max-w-md\">Glyph is a free QR code generator with built-in scan analytics. Generate codes instantly, scan from your camera, and track every scan — location, device, time. All for $3/month instead of $49.</p><div class=\"module-recessed p-4 inline-flex flex-col gap-1 max-w-xs\"><div class=\"flex items-center gap-3\"><span class=\"label\">others</span><span class=\"text-[14px] line-through text-[var(--text-tertiary)]\">$49/month</span></div><div class=\"flex items-center gap-3\"><span class=\"label text-[var(--accent)]\">glyph</span><span class=\"text-[14px] font-medium\">$3/month</span><span class=\"led led-active\"></span></div><p class=\"text-[11px] text-[var(--text-tertiary)] mt-1 lowercase\">same scans. same data. less noise.</p></div></div><div class=\"animate-in\" style=\"animation-delay:200ms\"><div class=\"module p-8 max-w-xl mx-auto w-full\"><div class=\"flex flex-col gap-6\"><div class=\"flex flex-col gap-2\"><span class=\"label\">destination url</span><div class=\"flex gap-3\"><input type=\"url\" placeholder=\"https://your-link.com\" class=\"hw-input flex-1\" autofocus=\"\" value=\"\"/><button disabled=\"\" class=\"keycap keycap-accent keycap-md disabled:opacity-40 disabled:cursor-not-allowed\">generate</button></div></div><div class=\"flex justify-center\"><div class=\"module-recessed p-6 flex items-center justify-center\" style=\"min-height:200px;min-width:200px\"><div class=\"flex flex-col items-center gap-3\"><div class=\"w-[120px] h-[120px] border-2 border-dashed border-[var(--border)] rounded-lg flex items-center justify-center\"><svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--text-tertiary)\" stroke-width=\"1.5\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"></rect><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"></rect><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\"></rect><rect x=\"14\" y=\"14\" width=\"3\" height=\"3\"></rect><rect x=\"18\" y=\"14\" width=\"3\" height=\"3\"></rect><rect x=\"14\" y=\"18\" width=\"3\" height=\"3\"></rect><rect x=\"18\" y=\"18\" width=\"3\" height=\"3\"></rect></svg></div><span class=\"label\">enter a url above</span></div></div></div><p class=\"text-center text-[12px] text-[var(--text-tertiary)] lowercase tracking-wide\">instant. no signup. no email.</p></div></div></div></div></section><section class=\"max-w-5xl mx-auto px-6 py-20\"><div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 stagger\"><div class=\"module p-6 flex flex-col gap-4\"><div class=\"flex items-center gap-3\"><span class=\"led led-active\"></span><span class=\"label\">generate</span></div><p class=\"text-[14px] text-[var(--text-secondary)] leading-relaxed\">Create QR codes instantly. No signup, no limits. Static codes free forever.</p><div class=\"module-recessed p-3 flex items-center justify-center\"><svg width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--text-secondary)\" stroke-width=\"1\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"></rect><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"></rect><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\"></rect><circle cx=\"17.5\" cy=\"17.5\" r=\"2.5\"></circle></svg></div></div><div class=\"module p-6 flex flex-col gap-4\"><div class=\"flex items-center gap-3\"><span class=\"led led-active\"></span><span class=\"label\">scan</span></div><p class=\"text-[14px] text-[var(--text-secondary)] leading-relaxed\">Point your camera at any QR code. Instant decode, no app needed. Works on every device.</p><a class=\"keycap keycap-light keycap-sm self-start no-underline\" href=\"/scan\">open scanner</a></div><div class=\"module p-6 flex flex-col gap-4\"><div class=\"flex items-center gap-3\"><span class=\"led led-active\"></span><span class=\"label\">track</span></div><p class=\"text-[14px] text-[var(--text-secondary)] leading-relaxed\">See who scans your codes. Location, device, browser, time. Real data, real-time.</p><div class=\"flex items-center gap-2\"><span class=\"text-[11px] text-[var(--text-tertiary)] lowercase\">pro feature</span><span class=\"text-[11px] text-[var(--accent)] font-medium\">$3/mo</span></div></div></div></section><section class=\"max-w-5xl mx-auto px-6 py-16\"><h2 class=\"text-[11px] font-medium text-[var(--text-tertiary)] uppercase tracking-[0.15em] mb-10\">How it works</h2><div class=\"grid grid-cols-1 md:grid-cols-4 gap-6 stagger\"><div class=\"flex flex-col gap-2\"><span class=\"font-mono text-[12px] text-[var(--accent)]\">01</span><span class=\"text-[15px] font-medium lowercase\">paste a url</span><span class=\"text-[13px] text-[var(--text-secondary)]\">Any link. Any page.</span></div><div class=\"flex flex-col gap-2\"><span class=\"font-mono text-[12px] text-[var(--accent)]\">02</span><span class=\"text-[15px] font-medium lowercase\">get your code</span><span class=\"text-[13px] text-[var(--text-secondary)]\">Download PNG or copy SVG.</span></div><div class=\"flex flex-col gap-2\"><span class=\"font-mono text-[12px] text-[var(--accent)]\">03</span><span class=\"text-[15px] font-medium lowercase\">place it anywhere</span><span class=\"text-[13px] text-[var(--text-secondary)]\">Print, screen, packaging.</span></div><div class=\"flex flex-col gap-2\"><span class=\"font-mono text-[12px] text-[var(--accent)]\">04</span><span class=\"text-[15px] font-medium lowercase\">watch the scans</span><span class=\"text-[13px] text-[var(--text-secondary)]\">Real-time analytics dashboard.</span></div></div></section><section class=\"max-w-5xl mx-auto px-6 py-20\" id=\"pricing\"><h2 class=\"text-[11px] font-medium text-[var(--text-tertiary)] uppercase tracking-[0.15em] mb-10\">Pricing</h2><div class=\"grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl\"><div class=\"module p-6 flex flex-col gap-4\"><div class=\"flex items-center justify-between\"><span class=\"text-[18px] font-medium lowercase\">free</span><span class=\"text-[13px] text-[var(--text-secondary)]\">$0 / forever</span></div><ul class=\"flex flex-col gap-2 text-[13px] text-[var(--text-secondary)]\"><li class=\"flex items-center gap-2\"><span class=\"led led-active\"></span>unlimited qr generation</li><li class=\"flex items-center gap-2\"><span class=\"led led-active\"></span>camera scanner</li><li class=\"flex items-center gap-2\"><span class=\"led led-active\"></span>3 dynamic (trackable) codes</li><li class=\"flex items-center gap-2\"><span class=\"led\"></span><span class=\"text-[var(--text-tertiary)]\">scan analytics</span></li><li class=\"flex items-center gap-2\"><span class=\"led\"></span><span class=\"text-[var(--text-tertiary)]\">custom colors / logo</span></li></ul><a class=\"keycap keycap-light keycap-md self-start no-underline mt-2\" href=\"/\">start free</a></div><div class=\"module-dark p-6 flex flex-col gap-4 text-[var(--text-on-dark)]\"><div class=\"flex items-center justify-between\"><span class=\"text-[18px] font-medium lowercase\">pro</span><span class=\"text-[13px] text-[var(--text-on-dark-secondary)]\">$3 / month</span></div><ul class=\"flex flex-col gap-2 text-[13px]\"><li class=\"flex items-center gap-2\"><span class=\"led led-active\"></span>everything in free</li><li class=\"flex items-center gap-2\"><span class=\"led led-active\"></span>unlimited dynamic codes</li><li class=\"flex items-center gap-2\"><span class=\"led led-active\"></span>full scan analytics</li><li class=\"flex items-center gap-2\"><span class=\"led led-active\"></span>custom colors and logo</li><li class=\"flex items-center gap-2\"><span class=\"led led-active\"></span>bulk csv generation</li><li class=\"flex items-center gap-2\"><span class=\"led led-active\"></span>api access</li></ul><a class=\"keycap keycap-accent keycap-md self-start no-underline mt-2\" href=\"/pricing\">go pro — $3/mo</a></div></div></section><section class=\"max-w-5xl mx-auto px-6 py-20\"><h2 class=\"text-[11px] font-medium text-[var(--text-tertiary)] uppercase tracking-[0.15em] mb-10\">Questions</h2><div class=\"flex flex-col gap-4 max-w-2xl\"><details class=\"module p-4 cursor-pointer group\"><summary class=\"text-[14px] font-medium lowercase list-none flex items-center justify-between\">Is the free tier really unlimited?<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--text-tertiary)\" stroke-width=\"2\" class=\"transition-transform group-open:rotate-45 shrink-0 ml-4\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"></line><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line></svg></summary><p class=\"text-[13px] text-[var(--text-secondary)] mt-3 leading-relaxed\">Yes. Generate and scan as many static QR codes as you want, forever. No email required, no hidden limits.</p></details><details class=\"module p-4 cursor-pointer group\"><summary class=\"text-[14px] font-medium lowercase list-none flex items-center justify-between\">What is a dynamic QR code?<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--text-tertiary)\" stroke-width=\"2\" class=\"transition-transform group-open:rotate-45 shrink-0 ml-4\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"></line><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line></svg></summary><p class=\"text-[13px] text-[var(--text-secondary)] mt-3 leading-relaxed\">A dynamic QR code routes through Glyph before reaching your destination. This lets us track every scan — location, device, browser, and time — without changing the printed code.</p></details><details class=\"module p-4 cursor-pointer group\"><summary class=\"text-[14px] font-medium lowercase list-none flex items-center justify-between\">How is this so much cheaper than competitors?<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--text-tertiary)\" stroke-width=\"2\" class=\"transition-transform group-open:rotate-45 shrink-0 ml-4\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"></line><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line></svg></summary><p class=\"text-[13px] text-[var(--text-secondary)] mt-3 leading-relaxed\">We keep it simple. No enterprise sales team, no bloated feature set. QR codes are not complicated technology. We charge what they are worth.</p></details><details class=\"module p-4 cursor-pointer group\"><summary class=\"text-[14px] font-medium lowercase list-none flex items-center justify-between\">Can I use Glyph for my restaurant or business?<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--text-tertiary)\" stroke-width=\"2\" class=\"transition-transform group-open:rotate-45 shrink-0 ml-4\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"></line><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line></svg></summary><p class=\"text-[13px] text-[var(--text-secondary)] mt-3 leading-relaxed\">Absolutely. Most of our users are restaurants, retailers, and event organizers who need QR codes for menus, payments, or check-ins — and want to know how often they get scanned.</p></details><details class=\"module p-4 cursor-pointer group\"><summary class=\"text-[14px] font-medium lowercase list-none flex items-center justify-between\">What payment methods do you accept?<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--text-tertiary)\" stroke-width=\"2\" class=\"transition-transform group-open:rotate-45 shrink-0 ml-4\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"></line><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line></svg></summary><p class=\"text-[13px] text-[var(--text-secondary)] mt-3 leading-relaxed\">CashApp, Bitcoin, Ethereum, and Solana. We are adding Stripe (credit/debit cards) soon.</p></details><details class=\"module p-4 cursor-pointer group\"><summary class=\"text-[14px] font-medium lowercase list-none flex items-center justify-between\">Can I change the destination URL after printing?<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--text-tertiary)\" stroke-width=\"2\" class=\"transition-transform group-open:rotate-45 shrink-0 ml-4\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"></line><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line></svg></summary><p class=\"text-[13px] text-[var(--text-secondary)] mt-3 leading-relaxed\">Yes — that is the point of dynamic codes. Change where your QR code points without reprinting. Your analytics carry over.</p></details><details class=\"module p-4 cursor-pointer group\"><summary class=\"text-[14px] font-medium lowercase list-none flex items-center justify-between\">Is there an API?<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--text-tertiary)\" stroke-width=\"2\" class=\"transition-transform group-open:rotate-45 shrink-0 ml-4\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"></line><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line></svg></summary><p class=\"text-[13px] text-[var(--text-secondary)] mt-3 leading-relaxed\">Pro subscribers get API access for programmatic QR generation and analytics retrieval. Documentation available after signup.</p></details></div></section></main><footer class=\"border-t border-[var(--border-subtle)] mt-auto\"><div class=\"max-w-5xl mx-auto px-6 py-8 flex items-center justify-between\"><div class=\"flex items-center gap-4\"><span class=\"text-[11px] text-[var(--text-tertiary)] lowercase tracking-wide\">glyph by<!-- --> <a target=\"_blank\" class=\"text-[var(--text-secondary)] hover:text-[var(--text-primary)] no-underline transition-colors\" href=\"https://calyvent.com\">calyvent</a></span><span class=\"text-[11px] text-[var(--text-tertiary)]\">© <!-- -->2026</span></div><div class=\"text-[11px] text-[var(--text-tertiary)] lowercase tracking-wide\">last updated: 2026-03-25</div></div></footer><!--$--><!--/$--><script src=\"/_next/static/chunks/00gq-v0e07i1q.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[39756,[\\\"/_next/static/chunks/01xlw8hd842-c.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"default\\\"]\\n3:I[37457,[\\\"/_next/static/chunks/01xlw8hd842-c.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"default\\\"]\\n4:I[56850,[\\\"/_next/static/chunks/01xlw8hd842-c.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\",\\\"/_next/static/chunks/04fv~hacgd4tv.js\\\",\\\"/_next/static/chunks/0qk6cwce9v.am.js\\\"],\\\"Nav\\\"]\\n11:I[68027,[\\\"/_next/static/chunks/01xlw8hd842-c.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"default\\\",1]\\n:HL[\\\"/_next/static/chunks/0h964wbq8x5co.css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/media/